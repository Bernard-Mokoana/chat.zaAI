        <mxCell id="doc-title" value="Open Source Stack Overview" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="50" y="1265" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="doc-1" value="• Frontend: Nginx/Caddy (reverse proxy, SSL/TLS), Varnish (HTTP caching) • Backend: FastAPI + Python• Data: PostgreSQL (SQL), MinIO (S3-compatible object storage)" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="50" y="1285" width="1300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="doc-2" value="• Monitoring: Prometheus + Grafana (metrics/dashboards), ELK/Loki (log aggregation) • Auth: Keycloak (IAM/OIDC) • Email: Mailhog (testing), Postfix (production SMTP)" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="50" y="1305" width="1300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="doc-3" value="• Analytics: Matomo (privacy-respecting alternative) • Deployment: Docker + Kubernetes (K8s for orchestration) • Free Tiers: Hugging Face (inference), Lemonsqueezy/Stripe free tier (billing)" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="50" y="1325" width="1300" height="20" as="geometry" />
